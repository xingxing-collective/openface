{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "@openface/docs",
  "description": "A Bun + TypeScript CLI for local NLP workflows powered by Hugging Face Transformers.",
  "colors": {
    "primary": "#D39B12",
    "light": "#F7C948",
    "dark": "#A66C00"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "body": {
      "family": "Fragment Mono"
    },
    "heading": {
      "family": "DM Sans"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Commands",
            "pages": [
              "commands/pull",
              "commands/translation",
              "commands/text-generation"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/repl",
              "reference/configuration",
              "reference/architecture"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/xingxing-collective/openface",
        "icon": "github"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/xingxing-collective/openface"
    }
  }
}
